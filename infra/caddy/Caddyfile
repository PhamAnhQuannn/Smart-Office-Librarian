{
	servers {
		protocols h1 h2
	}
	admin off
	email admin@{$DOMAIN:localhost}
}

# When DOMAIN is not set, falls back to http://35.175.156.119 (HTTP only, bare IP).
# When DOMAIN is set to a real hostname (e.g. embedlyzer.com), Caddy auto-provisions
# a free Let's Encrypt TLS certificate and serves HTTPS automatically.
{$DOMAIN:http://35.175.156.119} {
	encode zstd gzip

	# Security headers (active for HTTPS; harmless for HTTP)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@api path /api/* /metrics /health /ready
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy frontend:3101
	}
}
