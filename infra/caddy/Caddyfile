{
	servers {
		protocols h1 h2
	}
	admin off
	email admin@{$DOMAIN}
}

# Replace {$DOMAIN} with your real domain (e.g. embedlyzer.com) or set the
# DOMAIN environment variable in docker-compose. Caddy auto-provisions TLS.
{$DOMAIN:35.175.156.119} {
	encode zstd gzip

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@api path /api/* /metrics /health /ready
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy frontend:3101
	}
}
