aws_region           = "us-east-1"
project_name         = "embedlyzer"
environment          = "prod"
availability_zone    = "us-east-1a"
lightsail_bundle_id  = "medium_2_0"
lightsail_blueprint_id = "ubuntu_22_04"

# Option A: reference an existing Lightsail key pair
ssh_key_pair_name = "embedlyzer-prod"

# Option B: leave ssh_key_pair_name empty and provide ssh_public_key to create one
# ssh_key_pair_name = ""
# ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... user@example"

create_static_ip = true

tags = {
	Owner       = "engineering"
	CostCenter  = "platform"
	Compliance  = "mvp"
}
