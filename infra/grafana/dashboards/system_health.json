{
  "title": "System Health",
  "description": "Error rates, DB pool, and process health",
  "uid": "embedlyzer-system-health",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 }, "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "job:librarian_http_5xx_rate:ratio5m", "legendFormat": "5xx ratio" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Refusal Rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 }, "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "job:librarian_refusals_rate:ratio5m", "legendFormat": "Refusal ratio" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 }, "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "job:librarian_embedding_cache_hit_ratio:rate5m", "legendFormat": "Embedding cache hit ratio" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ingestion Pipeline p95 Duration (s)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "job:librarian_ingest_duration_seconds:p95_5m", "legendFormat": "Ingest p95" },
        { "refId": "B", "expr": "job:librarian_ingest_failure_rate:ratio5m", "legendFormat": "Ingest failure rate" }
      ]
    }
  ]
}
