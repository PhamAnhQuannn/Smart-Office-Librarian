{
  "title": "User Experience",
  "description": "Active streams, confidence distribution, and refusal reasons",
  "uid": "embedlyzer-ux",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active SSE Streams",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "job:librarian_active_streams:sum", "legendFormat": "Active streams" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Confidence Level Distribution",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "refId": "A", "expr": "rate(librarian_response_confidence_total{level='HIGH'}[5m])", "legendFormat": "HIGH" },
        { "refId": "B", "expr": "rate(librarian_response_confidence_total{level='MEDIUM'}[5m])", "legendFormat": "MEDIUM" },
        { "refId": "C", "expr": "rate(librarian_response_confidence_total{level='LOW'}[5m])", "legendFormat": "LOW" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Refusal Reasons",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(librarian_refusals_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Query Feedback (thumbs up/down)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(librarian_feedback_total[5m])",
          "legendFormat": "{{rating}}"
        }
      ]
    }
  ]
}
