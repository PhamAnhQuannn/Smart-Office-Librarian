# --------------------------------------
# OS / editor noise
# --------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# --------------------------------------
# Secrets and local env files
# --------------------------------------
.env
.env.*
!.env.example

backend/.env
backend/.env.*
!backend/.env.example

frontend/.env.local
frontend/.env.*
!frontend/.env.local.example

# --------------------------------------
# Python / backend artifacts
# --------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

.venv/
venv/
backend/.venv/
backend/venv/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

.coverage
coverage.xml
htmlcov/

*.egg-info/
build/
dist/

# --------------------------------------
# Node / frontend artifacts
# --------------------------------------
node_modules/
frontend/node_modules/

frontend/.next/
frontend/out/
frontend/dist/
frontend/coverage/
frontend/.turbo/
frontend/.eslintcache

npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --------------------------------------
# Logs / temp
# --------------------------------------
*.log
logs/
tmp/
temp/

# --------------------------------------
# Infra / runtime secrets
# --------------------------------------
infra/caddy/certs/
infra/docker/.env

# Terraform local state
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --------------------------------------
# Evaluation outputs
# --------------------------------------
evaluation/results/*
!evaluation/results/.gitkeep

# --------------------------------------
# Keep docs tracked (canonical source)
# Ignore only temp files inside docs
# --------------------------------------
docs/**/*.tmp
docs/**/*.bak
