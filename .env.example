# Embedlyzer environment variables
# Copy this file to .env (or source it) and fill in real values.
# Never commit real secrets.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production | testing
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://embedlyzer:embedlyzer@localhost:5432/embedlyzer
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                          # required
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.0

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=...                           # required
PINECONE_INDEX_NAME=embedlyzer

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-at-least-32-chars!!   # required; min 32 characters
JWT_EXPIRY_SECONDS=3600

# ── RAG behaviour ─────────────────────────────────────────────────────────────
DEFAULT_THRESHOLD=0.75
DEFAULT_NAMESPACE=dev
MAX_CONTEXT_CHUNKS=5
EMBEDDING_CACHE_TTL_SECONDS=86400

# ── Rate limiting & concurrency ───────────────────────────────────────────────
RATE_LIMIT_HOURLY=50
CONCURRENCY_LIMIT=5
STREAM_SLOT_TTL=90

# ── GitHub connector ──────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                           # required for private repos

# ── Budget / cost control ─────────────────────────────────────────────────────
MONTHLY_TOKEN_BUDGET=1000000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Used by the frontend dev server and BFF routes.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:8000

# ── Observability ─────────────────────────────────────────────────────────────
# Prometheus metrics are exposed at /metrics (no auth required).
# Grafana default URL (dev): http://localhost:3001
