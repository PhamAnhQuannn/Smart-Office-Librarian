APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# Choose either JWT_SECRET directly or the encrypted secret pair below.
JWT_SECRET=change-me-in-production
JWT_SECRET_ENCRYPTED=
JWT_SECRET_ENCRYPTION_KEY=

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/embedlyzer
DB_HOST=localhost
DB_PORT=5432
DB_NAME=embedlyzer
DB_USER=postgres
DB_PASSWORD=change-me

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

PINECONE_API_KEY=
PINECONE_INDEX_NAME=embedlyzer-dev
PINECONE_NAMESPACE=dev

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

BACKUP_DIR=./backups/postgres
RETENTION_DAYS=7

# ── GitHub connector ──────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── RAG behaviour ─────────────────────────────────────────────────────────────
DEFAULT_THRESHOLD=0.75
DEFAULT_NAMESPACE=dev
MAX_CONTEXT_CHUNKS=5
EMBEDDING_CACHE_TTL_SECONDS=86400
REDIS_TTL_SECONDS=3600

# ── OpenAI extra settings ─────────────────────────────────────────────────────
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.0

# ── Budget / cost control ─────────────────────────────────────────────────────
MONTHLY_TOKEN_BUDGET=1000000

# ── Application internals ─────────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
LOG_LEVEL=INFO
